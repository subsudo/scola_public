<Window x:Class="VerlaufsakteApp.ParticipantHintsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VerlaufsakteApp.Models"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="600"
        MinWidth="460"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#F6F2EA"
        Foreground="#292524">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#C8BFB2" CornerRadius="3" Margin="1,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HintFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#78716C" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,3" />
        </Style>

        <Style x:Key="HintTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="Foreground" Value="#292524" />
            <Setter Property="BorderBrush" Value="#D4C8BA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="HintDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="Foreground" Value="#292524" />
            <Setter Property="BorderBrush" Value="#D4C8BA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="HintButton" TargetType="Button">
            <Setter Property="MinHeight" Value="27" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Background" Value="#EEE7DC" />
            <Setter Property="Foreground" Value="#292524" />
            <Setter Property="BorderBrush" Value="#D4C8BA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryHintButton" TargetType="Button" BasedOn="{StaticResource HintButton}">
            <Setter Property="Background" Value="#D7E5CB" />
            <Setter Property="BorderBrush" Value="#AFC99B" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <DataTemplate x:Key="ActiveHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,9"
                    Padding="11"
                    Background="#FFFDF8"
                    BorderBrush="#DED4C7"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding TypeLabel}"
                               FontWeight="SemiBold"
                               Foreground="#292524" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Erledigt"
                                Tag="{Binding}"
                                Click="MarkDoneButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Visibility="{Binding ShowDate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource HintFieldLabel}" Text="Datum" />
                            <DatePicker Style="{StaticResource HintDatePicker}"
                                        SelectedDate="{Binding DateValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Visibility="{Binding ShowText, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource HintFieldLabel}" Text="Notiz (max. 60 Zeichen)" />
                            <TextBox Style="{StaticResource HintTextBox}"
                                     MaxLength="60"
                                     MinHeight="52"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Disabled"
                                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DoneHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,7"
                    Padding="9"
                    Background="#ECE6DC"
                    BorderBrush="#D6CCC0"
                    BorderThickness="1"
                    CornerRadius="7"
                    Opacity="0.78">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Reaktivieren"
                                Tag="{Binding}"
                                Click="ReactivateHintButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>
                    <TextBlock Text="{Binding TypeLabel}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Text="Aktive Hinweise erscheinen als farbige Markierungen und kompakte Pills."
                       Foreground="#78716C"
                       Margin="0,4,0,12" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Button Style="{StaticResource HintButton}" Content="+ Austritt" Click="AddExitButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ AM-Bericht" Click="AddAmButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Stellwerk" Click="AddStellwerkButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Notiz" Click="AddFreeButton_OnClick" />
        </WrapPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Aktive Hinweise"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ActiveItems}" ItemTemplate="{StaticResource ActiveHintTemplate}" />

                <TextBlock Text="Erledigte Hinweise"
                           FontWeight="SemiBold"
                           Foreground="#78716C"
                           Margin="0,12,0,8" />
                <ItemsControl ItemsSource="{Binding DoneItems}" ItemTemplate="{StaticResource DoneHintTemplate}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Style="{StaticResource HintButton}"
                    Content="Abbrechen"
                    Click="CancelButton_OnClick" />
            <Button Style="{StaticResource PrimaryHintButton}"
                    Content="Speichern"
                    Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
