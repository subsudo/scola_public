<Window x:Class="VerlaufsakteApp.ParticipantHintsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VerlaufsakteApp.Models"
        Title="{Binding WindowTitle}"
        Width="660"
        Height="640"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#202127"
        Foreground="#EFECE4">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="HintFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A29A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
        <Style x:Key="HintTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2B2C33" />
            <Setter Property="Foreground" Value="#F2EFE8" />
            <Setter Property="BorderBrush" Value="#3D3E46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style x:Key="HintButton" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Background" Value="#30313A" />
            <Setter Property="Foreground" Value="#EFECE4" />
            <Setter Property="BorderBrush" Value="#494A53" />
        </Style>
        <DataTemplate x:Key="ActiveHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Background="#282931"
                    BorderBrush="#3D3E46"
                    BorderThickness="1"
                    CornerRadius="9">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding TypeLabel}"
                               FontWeight="SemiBold"
                               Foreground="#F6F0DE" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Erledigt"
                                Tag="{Binding}"
                                Click="MarkDoneButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Visibility="{Binding ShowDate, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource HintFieldLabel}" Text="Datum (YYYY-MM-DD)" />
                                <TextBox Style="{StaticResource HintTextBox}" Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowMonth, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource HintFieldLabel}" Text="Monat (YYYY-MM)" />
                                <TextBox Style="{StaticResource HintTextBox}" Text="{Binding Month, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowSubject, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource HintFieldLabel}" Text="Fach" />
                                <TextBox Style="{StaticResource HintTextBox}" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel Visibility="{Binding ShowText, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource HintFieldLabel}" Text="Text" />
                                <TextBox Style="{StaticResource HintTextBox}" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowNote, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource HintFieldLabel}" Text="Notiz" />
                                <TextBox Style="{StaticResource HintTextBox}" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="DoneHintTemplate" DataType="{x:Type models:ParticipantHintEditorItem}">
            <Border Margin="0,0,0,8"
                    Padding="10"
                    Background="#24252B"
                    BorderBrush="#34353C"
                    BorderThickness="1"
                    CornerRadius="8"
                    Opacity="0.72">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource HintButton}"
                                Content="Reaktivieren"
                                Tag="{Binding}"
                                Click="ReactivateHintButton_OnClick" />
                        <Button Style="{StaticResource HintButton}"
                                Content="Löschen"
                                Tag="{Binding}"
                                Click="DeleteHintButton_OnClick" />
                    </StackPanel>
                    <TextBlock Text="{Binding TypeLabel}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Aktive Hinweise erscheinen auf der Kachel und im aufgeklappten Teilnehmerbereich."
                       Foreground="#A8A29A"
                       Margin="0,4,0,14" />
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,14">
            <Button Style="{StaticResource HintButton}" Content="+ Austritt" Click="AddExitButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ AM-Bericht" Click="AddAmButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Stellwerk-Test" Click="AddStellwerkButton_OnClick" />
            <Button Style="{StaticResource HintButton}" Content="+ Freier Hinweis" Click="AddFreeButton_OnClick" />
        </WrapPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Aktive Hinweise"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ActiveItems}" ItemTemplate="{StaticResource ActiveHintTemplate}" />

                <TextBlock Text="Erledigte Hinweise"
                           FontWeight="SemiBold"
                           Foreground="#A8A29A"
                           Margin="0,14,0,8" />
                <ItemsControl ItemsSource="{Binding DoneItems}" ItemTemplate="{StaticResource DoneHintTemplate}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Style="{StaticResource HintButton}"
                    Content="Abbrechen"
                    Click="CancelButton_OnClick" />
            <Button Style="{StaticResource HintButton}"
                    Content="Speichern"
                    FontWeight="SemiBold"
                    Click="SaveButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
