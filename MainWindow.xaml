<Window x:Class="VerlaufsakteApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:VerlaufsakteApp.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Scola"
        SizeChanged="MainWindow_OnSizeChanged"
        StateChanged="MainWindow_OnStateChanged"
        Activated="MainWindow_OnActivated"
        Deactivated="MainWindow_OnDeactivated"
        Closing="MainWindow_OnClosing"
        Width="520"
        Height="700"
        MinWidth="280"
        MinHeight="520"
        Background="{DynamicResource Brush.WindowBg}"
        FontFamily="Segoe UI"
        FontSize="{DynamicResource Density.WindowFontSize}"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <sys:Double x:Key="Density.WindowFontSize">13</sys:Double>
        <sys:Double x:Key="Density.NameFontSize">13</sys:Double>
        <sys:Double x:Key="Density.SecondaryFontSize">11</sys:Double>
        <sys:Double x:Key="Density.ActionButtonFontSize">11</sys:Double>
        <sys:Double x:Key="Density.PrimaryButtonFontSize">13</sys:Double>
        <sys:Double x:Key="Density.ActionButtonMinHeight">28</sys:Double>
        <sys:Double x:Key="Density.PrimaryButtonMinHeight">34</sys:Double>
        <sys:Double x:Key="Density.ActionRowItemHeight">30</sys:Double>
        <sys:Double x:Key="Density.SubtleIconButtonSize">28</sys:Double>
        <sys:Double x:Key="Density.SubtleIconFontSize">13</sys:Double>
        <Thickness x:Key="Density.CardPadding">10,7</Thickness>
        <Thickness x:Key="Density.CardMargin">0,0,0,4</Thickness>
        <Thickness x:Key="Density.ActionButtonPadding">10,5</Thickness>
        <Thickness x:Key="Density.ActionButtonMargin">0,0,4,0</Thickness>
        <Thickness x:Key="Density.PrimaryButtonPadding">18,8</Thickness>
        <Thickness x:Key="Density.PresenceCheckBoxMargin">0,0,8,0</Thickness>
        <Thickness x:Key="Density.CollapsedStripPadding">10,8</Thickness>
        <Thickness x:Key="Density.AbsenceStatusMargin">12,0,0,0</Thickness>
        <Thickness x:Key="Density.NotFoundHintMargin">0,4,0,0</Thickness>
        <Thickness x:Key="Density.WideActionRowMargin">12,0,0,0</Thickness>
        <Thickness x:Key="Density.BatchToggleMargin">0,8,0,0</Thickness>
        <Thickness x:Key="Density.BatchPanelPadding">10</Thickness>
        <Thickness x:Key="Density.BatchDescriptionMargin">0,0,0,8</Thickness>
        <Thickness x:Key="Density.BatchButtonsMargin">0,10,0,0</Thickness>
        <Thickness x:Key="Density.BatchProgressMargin">0,8,0,0</Thickness>

        <!-- Title Bar Buttons -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <Style x:Key="SubtleIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{DynamicResource Density.SubtleIconButtonSize}" />
            <Setter Property="Height" Value="{DynamicResource Density.SubtleIconButtonSize}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="{DynamicResource Density.SubtleIconFontSize}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Buttons (Ordner, Akte, BU, Eintrag) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{DynamicResource Density.ActionButtonPadding}" />
            <Setter Property="Margin" Value="{DynamicResource Density.ActionButtonMargin}" />
            <Setter Property="FontSize" Value="{DynamicResource Density.ActionButtonFontSize}" />
            <Setter Property="MinHeight" Value="{DynamicResource Density.ActionButtonMinHeight}" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.InputHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.PanelBg}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Auswerten Button -->
        <Style x:Key="EvaluateButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="{DynamicResource Density.PrimaryButtonFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="{DynamicResource Density.PrimaryButtonPadding}" />
            <Setter Property="MinHeight" Value="{DynamicResource Density.PrimaryButtonMinHeight}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{DynamicResource Brush.Accent}"
                                BorderBrush="{DynamicResource Brush.Accent}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.AccentPressed}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.AccentPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Name Button -->
        <Style x:Key="NameButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="{DynamicResource Density.NameFontSize}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="NameText"
                                   Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   FontSize="{TemplateBinding FontSize}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NameText" Property="TextDecorations" Value="Underline" />
                                <Setter TargetName="NameText" Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Brush.InputBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.InputHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Collapsed Strip -->
        <Style x:Key="CollapsedStripStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="{DynamicResource Density.CollapsedStripPadding}" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.CardHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern thin Scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="ThumbBorder"
                                                                    Background="{DynamicResource Brush.Border}"
                                                                    CornerRadius="3"
                                                                    Margin="1,0" />
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Brush.InputHoverBorder}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Preview Table / Status Dropdown -->
        <Style x:Key="StatusComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Brush.InputBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource StatusComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" />

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="8,0,6,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False" />

                                <Border x:Name="ArrowHost"
                                        Grid.Column="1"
                                        Background="{DynamicResource Brush.PanelBg}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1,0,0,0"
                                        CornerRadius="0,3,3,0">
                                    <Path HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{DynamicResource Brush.SecondaryText}"
                                          Data="M 0 0 L 4 4 L 8 0 Z" />
                                </Border>
                            </Grid>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        Margin="0,2,0,0"
                                        Background="{DynamicResource Brush.PanelBg}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Brush.InputHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                <Setter TargetName="ArrowHost" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ArrowHost" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="28" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource Brush.InputBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>

        <Style x:Key="PreviewDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="PreviewDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Border}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.CardHover}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewWrapTextBlockStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxHeight" Value="48" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>

        <Style x:Key="PresenceCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="{DynamicResource Density.PresenceCheckBoxMargin}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SubtleProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#7FAF86" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Grid ClipToBounds="True">
                                <Rectangle x:Name="Indicator"
                                           Width="30"
                                           RadiusX="2"
                                           RadiusY="2"
                                           Fill="{TemplateBinding Foreground}"
                                           Opacity="0.8"
                                           HorizontalAlignment="Left">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform X="-34" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-34"
                                                             To="108"
                                                             Duration="0:0:1.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <SolidColorBrush x:Key="Brush.ScheduleStatusExtForeground" Color="#3E7156" />
        <SolidColorBrush x:Key="Brush.ScheduleStatusExtBackground" Color="#B9E1C6" />
        <SolidColorBrush x:Key="Brush.ScheduleStatusDispForeground" Color="#745050" />
        <SolidColorBrush x:Key="Brush.ScheduleStatusDispBackground" Color="#E4C1C1" />
        <sys:Double x:Key="Density.MiniScheduleScale">1</sys:Double>

        <Style x:Key="MiniScheduleCellBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="BorderThickness" Value="0.45" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="3,3,3,4" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style x:Key="MiniScheduleHeaderBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="BorderThickness" Value="0.45" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0,2" />
        </Style>

        <Style x:Key="MiniScheduleLunchBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.CardHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.SecondaryText}" />
            <Setter Property="BorderThickness" Value="0.3" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <DataTemplate x:Key="MiniScheduleCellTemplate" DataType="{x:Type models:ParticipantMiniScheduleCell}">
            <Border Style="{StaticResource MiniScheduleCellBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="PrimaryTextBlock"
                               Grid.Row="0"
                               Text="{Binding DisplayGroup}"
                               FontWeight="SemiBold"
                               FontSize="10"
                               TextWrapping="NoWrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0"
                               TextAlignment="Center"
                               Foreground="{DynamicResource Brush.PrimaryText}" />

                    <Grid x:Name="MetaGrid"
                          Grid.Row="1"
                          Margin="0,0,0,0"
                          HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TeacherTextBlock"
                                   Grid.Column="0"
                                   Text="{Binding DisplayTeacher}"
                                   FontSize="8.4"
                                   Foreground="{DynamicResource Brush.SecondaryText}"
                                   TextWrapping="NoWrap"
                                   HorizontalAlignment="Left"
                                   Margin="1,0,0,0" />
                        <TextBlock x:Name="RoomTextBlock"
                                   Grid.Column="2"
                                   Text="{Binding DisplayRoom}"
                                   FontSize="7.6"
                                   Foreground="{DynamicResource Brush.SecondaryText}"
                                   TextWrapping="NoWrap"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,2,0" />
                    </Grid>

                    <TextBlock x:Name="AdditionalTextBlock"
                               Grid.Row="2"
                               Margin="0,0,0,0"
                               FontSize="6.4"
                               Foreground="{DynamicResource Brush.SubtleText}"
                               TextWrapping="NoWrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ParticipantMiniScheduleCellStatus.External}">
                    <Setter TargetName="PrimaryTextBlock" Property="Text" Value=" ext " />
                    <Setter TargetName="PrimaryTextBlock" Property="Foreground" Value="{DynamicResource Brush.ScheduleStatusExtForeground}" />
                    <Setter TargetName="PrimaryTextBlock" Property="Background" Value="{DynamicResource Brush.ScheduleStatusExtBackground}" />
                    <Setter TargetName="PrimaryTextBlock" Property="FontSize" Value="8.2" />
                    <Setter TargetName="MetaGrid" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AdditionalTextBlock" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ParticipantMiniScheduleCellStatus.Dispensed}">
                    <Setter TargetName="PrimaryTextBlock" Property="Text" Value=" disp " />
                    <Setter TargetName="PrimaryTextBlock" Property="Foreground" Value="{DynamicResource Brush.ScheduleStatusDispForeground}" />
                    <Setter TargetName="PrimaryTextBlock" Property="Background" Value="{DynamicResource Brush.ScheduleStatusDispBackground}" />
                    <Setter TargetName="PrimaryTextBlock" Property="FontSize" Value="8.2" />
                    <Setter TargetName="MetaGrid" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AdditionalTextBlock" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasPrimaryEntry}" Value="False" />
                        <Condition Binding="{Binding IsExternal}" Value="False" />
                        <Condition Binding="{Binding IsDispensed}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="PrimaryTextBlock" Property="Text" Value="-" />
                    <Setter TargetName="PrimaryTextBlock" Property="Foreground" Value="{DynamicResource Brush.SubtleText}" />
                </MultiDataTrigger>
                <DataTrigger Binding="{Binding HasSupplementalDaz}" Value="True">
                    <Setter TargetName="PrimaryTextBlock" Property="Margin" Value="0,-2,0,0" />
                    <Setter TargetName="TeacherTextBlock" Property="Margin" Value="1,-2,0,0" />
                    <Setter TargetName="RoomTextBlock" Property="Margin" Value="0,-2,2,0" />
                    <Setter TargetName="AdditionalTextBlock" Property="Margin" Value="0,-2,0,0" />
                    <Setter TargetName="AdditionalTextBlock" Property="Text" Value="+DAZ" />
                    <Setter TargetName="AdditionalTextBlock" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="OverlayResultsScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="Transparent"
                              ClipToBounds="True">
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Margin="0,0,5,0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Width="8"
                                       Margin="0,2,1,2"
                                       Panel.ZIndex="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Stretch"
                                       Orientation="Vertical"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Height="8"
                                       Margin="2,0,7,1"
                                       Panel.ZIndex="1"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Bottom"
                                       Orientation="Horizontal"
                                       Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Participant Card Template -->
        <DataTemplate x:Key="ParticipantCardTemplate">
            <Border Padding="{DynamicResource Density.CardPadding}"
                    Margin="{DynamicResource Density.CardMargin}"
                    CornerRadius="6"
                    Opacity="{Binding DisplayOpacity}"
                    MouseLeftButtonDown="ParticipantCard_OnMouseLeftButtonDown">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Brush.CardBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    Grid.Column="0"
                                    VerticalAlignment="Center">
                            <CheckBox Style="{StaticResource PresenceCheckBoxStyle}"
                                      IsChecked="{Binding IsPresent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Checked="PresenceCheckBox_OnChecked"
                                      Unchecked="PresenceCheckBox_OnChecked" />
                            <TextBlock Text="{Binding MatchSymbol}"
                                       Foreground="{Binding MatchColor}"
                                       ToolTip="{Binding MatchTooltip}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowMatchSymbol, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="{Binding FullName}"
                                Style="{StaticResource NameButtonStyle}"
                                Click="NameButton_OnClick"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center" />

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="{DynamicResource Density.NotFoundHintMargin}">
                            <TextBlock Foreground="{DynamicResource Brush.SecondaryText}"
                                       FontSize="{DynamicResource Density.SecondaryFontSize}"
                                       Text="{Binding AbsenceStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowAbsenceStatus}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource Brush.SecondaryText}"
                                       FontSize="{DynamicResource Density.SecondaryFontSize}"
                                       Text="{Binding Initials}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasInitials}" Value="True" />
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowParticipantInitials}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource Brush.SecondaryText}"
                                       FontSize="{DynamicResource Density.SecondaryFontSize}"
                                       Text="Ordnername prüfen"
                                       Visibility="{Binding IsNotFound, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Grid>

                    <WrapPanel Grid.Row="0"
                               Grid.Column="1"
                               Margin="{DynamicResource Density.WideActionRowMargin}"
                               Orientation="Horizontal"
                               VerticalAlignment="Center"
                               ItemHeight="{DynamicResource Density.ActionRowItemHeight}">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenOdooButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenOdoo}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnOdoo, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Odoo" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenFolderButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenFolder}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnOrdner, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Ordner" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenAkteButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenAkte}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnAkte, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Akte" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenAkteBuButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenAkteBu}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnBu, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="BU" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="InsertEntryButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanInsertEntry}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnEintrag, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Eintrag BU" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenAkteBiButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenAkteBi}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnBi, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="BI" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="OpenAkteBeButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanOpenAkteBe}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnBe, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="BE" />
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Click="InsertEntryBiButton_OnClick"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding CanInsertEntryBi}"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowBtnEintragBi, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Eintrag BI" />
                        </Button>
                    </WrapPanel>

                    <Border x:Name="MiniScheduleTrayHost"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,8,0,0"
                            Background="Transparent"
                            ClipToBounds="True"
                            Loaded="MiniScheduleTrayHost_OnLoaded"
                            Unloaded="MiniScheduleTrayHost_OnUnloaded"
                            MaxHeight="0"
                            Opacity="0"
                            Visibility="Collapsed"
                            RenderTransformOrigin="0.5,0">
                        <Border.LayoutTransform>
                            <ScaleTransform ScaleX="{DynamicResource Density.MiniScheduleScale}"
                                            ScaleY="{DynamicResource Density.MiniScheduleScale}" />
                        </Border.LayoutTransform>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="0.96" />
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,4,0"
                                    MinWidth="224"
                                    MaxWidth="244"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMiniScheduleLoading}" Value="True">
                                                <Setter Property="Opacity" Value="0.78" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MiniScheduleSummary.State}" Value="{x:Static models:ParticipantMiniScheduleState.Unavailable}">
                                                <Setter Property="Opacity" Value="0.72" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <UniformGrid Grid.Row="0"
                                                 Columns="5"
                                                 Margin="0">
                                        <Border Style="{StaticResource MiniScheduleHeaderBorderStyle}" CornerRadius="4,0,0,0">
                                            <TextBlock Text="Mo" FontWeight="SemiBold" FontSize="9.5" Foreground="{DynamicResource Brush.SecondaryText}" HorizontalAlignment="Center" />
                                        </Border>
                                        <Border Style="{StaticResource MiniScheduleHeaderBorderStyle}">
                                            <TextBlock Text="Di" FontWeight="SemiBold" FontSize="9.5" Foreground="{DynamicResource Brush.SecondaryText}" HorizontalAlignment="Center" />
                                        </Border>
                                        <Border Style="{StaticResource MiniScheduleHeaderBorderStyle}">
                                            <TextBlock Text="Mi" FontWeight="SemiBold" FontSize="9.5" Foreground="{DynamicResource Brush.SecondaryText}" HorizontalAlignment="Center" />
                                        </Border>
                                        <Border Style="{StaticResource MiniScheduleHeaderBorderStyle}">
                                            <TextBlock Text="Do" FontWeight="SemiBold" FontSize="9.5" Foreground="{DynamicResource Brush.SecondaryText}" HorizontalAlignment="Center" />
                                        </Border>
                                        <Border Style="{StaticResource MiniScheduleHeaderBorderStyle}" CornerRadius="0,4,0,0">
                                            <TextBlock Text="Fr" FontWeight="SemiBold" FontSize="9.5" Foreground="{DynamicResource Brush.SecondaryText}" HorizontalAlignment="Center" />
                                        </Border>
                                    </UniformGrid>

                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding MiniScheduleSummary.MorningCells}"
                                                  ItemTemplate="{StaticResource MiniScheduleCellTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="5" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <Border Grid.Row="2"
                                            Style="{StaticResource MiniScheduleLunchBorderStyle}"
                                            Height="6"
                                            Margin="0" />

                                    <ItemsControl Grid.Row="3"
                                                  ItemsSource="{Binding MiniScheduleSummary.AfternoonCells}"
                                                  ItemTemplate="{StaticResource MiniScheduleCellTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="5" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.WindowBg}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource Brush.TitleBarBg}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource Brush.PrimaryText}"
                           FontWeight="SemiBold"
                           Text="Scola" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="SettingsButton_OnClick"
                            Content="⚙" />
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Click="MinimizeButton_OnClick"
                            Content="&#xE921;"
                            ToolTip="Minimieren" />
                    <Button x:Name="CollapseToggleButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="CollapseToggleButton_OnClick"
                            Content="▲"
                            FontSize="9"
                            FontWeight="Bold"
                            Foreground="{DynamicResource Brush.SecondaryText}"
                            ToolTip="Einklappen" />
                    <Button Style="{StaticResource WindowControlButtonStyle}"
                            Click="CloseButton_OnClick"
                            Content="&#xE8BB;"
                            ToolTip="Schliessen" />
                </StackPanel>
            </Grid>

            <Grid x:Name="WindowBodyContainer"
                  Grid.Row="1"
                  VerticalAlignment="Top"
                  ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="24" />
                </Grid.RowDefinitions>

                <!-- Main Content -->
                <Grid x:Name="MainContentGrid" Grid.Row="0" Margin="10,10,10,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                <!-- Collapsed Strip -->
                <Border x:Name="CollapsedStrip"
                        Grid.Row="0"
                        Margin="0,0,0,6"
                        Style="{StaticResource CollapsedStripStyle}"
                        Visibility="Collapsed"
                        MouseLeftButtonDown="CollapsedStrip_OnMouseLeftButtonDown">
                    <TextBlock x:Name="CollapsedStripText"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                               FontWeight="SemiBold"
                               Text="▶ Liste neu einfügen" />
                </Border>

                <!-- Input Area -->
                <Border x:Name="InputContainer"
                        Grid.Row="1"
                        Height="250"
                        Margin="0,0,0,6"
                        Background="{DynamicResource Brush.PanelBg}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBox x:Name="InputTextBox"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     TextChanged="InputTextBox_OnTextChanged" />
                            <TextBlock x:Name="PlaceholderText"
                                       Margin="12,10,0,0"
                                       Foreground="{DynamicResource Brush.SubtleText}"
                                       IsHitTestVisible="False"
                                       Text="Anwesenheitsliste hier einfügen (Ctrl+V)" />
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left">
                            <Button x:Name="EvaluateButton"
                                    Margin="0"
                                    Width="140"
                                    Height="34"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EvaluateButtonStyle}"
                                    Click="EvaluateButton_OnClick"
                                    Content="Auswerten"
                                    IsEnabled="False" />
                            <Button x:Name="ClearInputButton"
                                    Width="110"
                                    Height="34"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="ClearInputButton_OnClick"
                                    Content="Löschen" />
                            <StackPanel x:Name="EvaluateProgressPanel"
                                        Orientation="Horizontal"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <ProgressBar Width="72"
                                             Height="6"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource SubtleProgressBarStyle}"
                                             IsIndeterminate="True" />
                                <TextBlock x:Name="EvaluateProgressText"
                                           Foreground="{DynamicResource Brush.SecondaryText}"
                                           FontSize="{DynamicResource Density.SecondaryFontSize}"
                                           VerticalAlignment="Center"
                                           Text="Wird ausgewertet..." />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Results Area -->
                <Border x:Name="ResultsContainer"
                        Grid.Row="2"
                        Visibility="Collapsed"
                        Background="{DynamicResource Brush.PanelBg}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="6">
                    <ScrollViewer x:Name="ResultsScrollViewer"
                                  Style="{StaticResource OverlayResultsScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ResultsContentStack" Margin="0,0,2,0">
                            <ItemsControl ItemsSource="{Binding Participants}"
                                          ItemTemplate="{StaticResource ParticipantCardTemplate}" />

                            <DockPanel x:Name="ResultsActionsFooter"
                                       Margin="{DynamicResource Density.BatchToggleMargin}"
                                       LastChildFill="False">
                                <Button Style="{StaticResource SubtleIconButtonStyle}"
                                        DockPanel.Dock="Right"
                                        Content="&#xE74D;"
                                        ToolTip="Namensliste löschen"
                                        Click="ClearParticipantsButton_OnClick" />
                            </DockPanel>

                            <Border x:Name="BatchStripBorder"
                                    Margin="{DynamicResource Density.BatchToggleMargin}"
                                    Style="{StaticResource CollapsedStripStyle}"
                                    MouseLeftButtonDown="ToggleBatchPanel_OnMouseLeftButtonDown">
                                <TextBlock x:Name="BatchStripText"
                                           Foreground="{DynamicResource Brush.PrimaryText}"
                                           FontWeight="SemiBold"
                                           Text="▶ BU: Batch-Eintrag ⚡︎" />
                            </Border>

                            <Border x:Name="BatchPanelContainer"
                                    Margin="0,6,0,0"
                                    Background="{DynamicResource Brush.PanelBg}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="{DynamicResource Density.BatchPanelPadding}"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="120" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Der BU: Batch-Eintrag ist aktuell nur für BU und MO verfügbar. Bitte pro aktivem TN genau eine Zeile mit 4 tab-getrennten Spalten einfügen."
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               TextWrapping="Wrap"
                                               Margin="{DynamicResource Density.BatchDescriptionMargin}"
                                               FontSize="{DynamicResource Density.SecondaryFontSize}" />

                                    <TextBox x:Name="BatchInputTextBox"
                                             Grid.Row="1"
                                             MinHeight="90"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled" />

                                    <GridSplitter Grid.Row="2"
                                                  Height="6"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  ResizeDirection="Rows"
                                                  ResizeBehavior="PreviousAndNext"
                                                  ShowsPreview="True"
                                                  Background="{DynamicResource Brush.Border}" />

                                    <Grid Grid.Row="3"
                                          Margin="{DynamicResource Density.BatchButtonsMargin}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="ExecuteBatchButton"
                                                Grid.Column="0"
                                                Width="140"
                                                Height="34"
                                                Style="{StaticResource EvaluateButtonStyle}"
                                                Content="Batch ausführen ⚡︎"
                                                Click="ExecuteBatchButton_OnClick" />
                                        <Button Grid.Column="2"
                                                Width="140"
                                                Height="34"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Content="Inhalt löschen"
                                                Click="ClearBatchInputButton_OnClick" />
                                    </Grid>

                                    <TextBlock x:Name="BatchProgressText"
                                               Grid.Row="4"
                                               Margin="{DynamicResource Density.BatchProgressMargin}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               FontSize="{DynamicResource Density.SecondaryFontSize}"
                                               Text="Fortschritt: —" />

                                    <ItemsControl Grid.Row="5"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding BatchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
                                                            <Setter Property="Text">
                                                                <Setter.Value>
                                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                                        <Binding Path="Name" />
                                                                        <Binding Path="Message" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <Border x:Name="BiTodoStripBorder"
                                    Margin="{DynamicResource Density.BatchToggleMargin}"
                                    Style="{StaticResource CollapsedStripStyle}"
                                    MouseLeftButtonDown="ToggleBiTodoPanel_OnMouseLeftButtonDown">
                                <TextBlock x:Name="BiTodoStripText"
                                           Foreground="{DynamicResource Brush.PrimaryText}"
                                           FontWeight="SemiBold"
                                           Text="▶ BI: To-dos ⚡︎" />
                            </Border>

                            <Border x:Name="BiTodoPanelContainer"
                                    Margin="0,6,0,0"
                                    Background="{DynamicResource Brush.PanelBg}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="{DynamicResource Density.BatchPanelPadding}"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Sammelt aus den angegebenen Feldern die To-dos bei BI in ein neues, ungespeichertes Word-Dokument."
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               TextWrapping="Wrap"
                                               Margin="{DynamicResource Density.BatchDescriptionMargin}"
                                               FontSize="{DynamicResource Density.SecondaryFontSize}" />

                                    <Grid Grid.Row="1"
                                          Margin="{DynamicResource Density.BatchButtonsMargin}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button x:Name="ExecuteBiTodoButton"
                                                Grid.Column="0"
                                                Width="150"
                                                Height="34"
                                                Style="{StaticResource EvaluateButtonStyle}"
                                                Content="To-dos sammeln ⚡︎"
                                                Click="ExecuteBiTodoButton_OnClick" />
                                        <Button Grid.Column="2"
                                                Width="120"
                                                Height="34"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Content="Status leeren"
                                                Click="ClearBiTodoResultsButton_OnClick" />
                                        <StackPanel x:Name="BiTodoProgressPanel"
                                                    Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <ProgressBar Width="72"
                                                         Height="6"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"
                                                         Style="{StaticResource SubtleProgressBarStyle}"
                                                         IsIndeterminate="True" />
                                            <TextBlock x:Name="BiTodoProgressInlineText"
                                                       Foreground="{DynamicResource Brush.SecondaryText}"
                                                       FontSize="{DynamicResource Density.SecondaryFontSize}"
                                                       VerticalAlignment="Center"
                                                       Text="Wird gesammelt..." />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock x:Name="BiTodoProgressText"
                                               Grid.Row="2"
                                               Margin="{DynamicResource Density.BatchProgressMargin}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               FontSize="{DynamicResource Density.SecondaryFontSize}"
                                               Text="Fortschritt: —" />

                                    <ItemsControl Grid.Row="3"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding BiTodoResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.SecondaryText}" />
                                                            <Setter Property="Text">
                                                                <Setter.Value>
                                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                                        <Binding Path="DisplayName" />
                                                                        <Binding Path="Message" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border x:Name="StatusBarContainer"
                    Grid.Row="1"
                    Background="{DynamicResource Brush.StatusBarBg}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="10,0"
                    CornerRadius="0,0,8,8">
                <DockPanel>
                    <TextBlock x:Name="StatusBarVersion"
                               DockPanel.Dock="Right"
                               Foreground="{DynamicResource Brush.InputHoverBorder}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Text="" />
                    <TextBlock x:Name="StatusBarTimestamp"
                               DockPanel.Dock="Right"
                               Margin="0,0,10,0"
                               Foreground="{DynamicResource Brush.InputHoverBorder}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Text="" />
                    <TextBlock x:Name="StatusBarText"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Text="Bereit" />
                </DockPanel>
            </Border>
            </Grid>

            <!-- Toast Notification Overlay -->
            <ItemsControl x:Name="ToastContainer"
                          Grid.Row="1"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Right"
                          Margin="0,0,20,12"
                          IsHitTestVisible="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

        </Grid>
    </Border>
</Window>



