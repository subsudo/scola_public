<Window x:Class="VerlaufsakteApp.BatchFailureSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch mit Fehlern abgeschlossen"
        Width="560"
        MinWidth="520"
        SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.WindowBg}"
        FontFamily="Segoe UI"
        FontSize="13"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryText}" />
            <Setter Property="Background" Value="{DynamicResource Brush.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.InputHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{DynamicResource Brush.WindowBg}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="20"
                        Background="#3A331B"
                        BorderBrush="{DynamicResource Brush.Warning}"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock Text="!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Warning}" />
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Batch mit Fehlern abgeschlossen"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                               FontWeight="SemiBold"
                               FontSize="18" />
                    <TextBlock x:Name="SummaryTextBlock"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Nicht verarbeitete Einträge"
                               Foreground="{DynamicResource Brush.PrimaryText}"
                               FontWeight="SemiBold"
                               FontSize="14" />
                    <TextBlock Text="Die Batch-Liste in der App zeigt dieselben Details weiterhin an."
                               Margin="0,3,0,10"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               FontSize="11" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="360">
                        <ItemsControl x:Name="FailureItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Background="{DynamicResource Brush.CardBg}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{DynamicResource Brush.PrimaryText}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.SubtleText}"
                           FontSize="11"
                           Text="Der Batch wurde nicht unterbrochen; nur einzelne Einträge sind fehlgeschlagen." />
                <Button DockPanel.Dock="Right"
                        MinWidth="110"
                        Style="{StaticResource SecondaryButtonStyle}"
                        IsDefault="True"
                        Click="OkButton_OnClick"
                        Content="Schliessen" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
